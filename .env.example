# ─── Arbitrum Alpha Operator v6.0 ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.  NEVER commit .env to git.

# ── RPC Endpoints (Arbitrum One) ──────────────────────────────────────────────
ARB_RPC_URL=https://arb1.arbitrum.io/rpc
ARB_RPC_BACKUP_1=https://arbitrum.llamarpc.com
ARB_RPC_BACKUP_2=https://rpc.ankr.com/arbitrum

# ── Wallet (for active-mode execution only) ──────────────────────────────────
# WARNING: Keep this secret. Never share or commit.
ARB_PRIVATE_KEY=

# ── Telegram Alerts ──────────────────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Mode ──────────────────────────────────────────────────────────────────────
# Set to "true" to run Shadow Mirror only (no real transactions)
PASSIVE_MODE=true

# ── Sentiment API (optional) ─────────────────────────────────────────────────
# Leave blank for mock sentiment (returns neutral 0.0)
SENTIMENT_API_URL=

# ── Portfolio ─────────────────────────────────────────────────────────────────
# Starting capital — scales from 1000 to 5000
PORTFOLIO_USD=1000
